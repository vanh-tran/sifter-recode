{
  "name": "sifter-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "dev:webpack": "next dev --webpack",
    "build": "next build",
    "build:webpack": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '__tests__/worker/**' --exclude '__tests__/integration/**'",
    "test:worker": "vitest run '__tests__/worker/**'",
    "test:integration": "vitest run '__tests__/integration/**'",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@google-cloud/kms": "^5.5.1",
    "@google-cloud/storage": "^7.18.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@react-pdf/renderer": "^4.3.2",
    "@sifter/core": "workspace:*",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.89.0",
    "@tanstack/react-query": "^5.60.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "googleapis": "^173.0.0",
    "isomorphic-dompurify": "^3.16.0",
    "lucide-react": "^1.17.0",
    "mongodb": "^7.1.1",
    "next": "16.2.1",
    "next-view-transitions": "^0.3.5",
    "openai": "^6.16.0",
    "pdf-parse": "^2.4.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "strnum": "^2.1.2",
    "supabase": "^2.67.3",
    "tailwind-merge": "^3.5.0",
    "three": "^0.170.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.170.0",
    "eslint": "^10",
    "eslint-config-next": "16.2.1",
    "happy-dom": "^20.8.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": ["eslint --fix"]
  }
