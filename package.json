{
  "name": "sifter-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "dev:webpack": "next dev --webpack",
    "build": "next build",
    "build:webpack": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '__tests__/worker/**' --exclude '__tests__/integration/**'",
    "test:worker": "vitest run '__tests__/worker/**'",
    "test:integration": "vitest run '__tests__/integration/**'",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@google-cloud/kms": "^4.2.0",
    "@google-cloud/storage": "^7.21.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-navigation-menu": "^1.2.15",
    "@react-pdf/renderer": "^4.5.1",
    "@sifter/core": "workspace:*",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "@tanstack/react-query": "^5.101.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "googleapis": "^169.0.0",
    "isomorphic-dompurify": "^2.10.0",
    "lucide-react": "^0.575.0",
    "mongodb": "^7.3.0",
    "next": "16.2.9",
    "next-view-transitions": "^0.3.5",
    "openai": "^6.42.0",
    "pdf-parse": "^2.4.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "strnum": "^2.4.0",
    "supabase": "^2.105.0",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "happy-dom": "^20.10.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx}": ["eslint --fix"]
  }
