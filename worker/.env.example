# Sifter worker — copy to .env and fill in values.
# Loaded by worker via `import 'dotenv/config'` (see worker/src/index.ts).

# -----------------------------------------------------------------------------
# Required — queues (@sifter/core)
# -----------------------------------------------------------------------------
# Upstash Redis URL (TLS). Same value as on Vercel if Next.js enqueues jobs.
UPSTASH_REDIS_URL=

# -----------------------------------------------------------------------------
# Required — Supabase (service role; worker has no cookies)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Required — MongoDB (document OCR text / metadata)
# -----------------------------------------------------------------------------
MONGODB_URI=
# Optional; defaults to "sifter"
# MONGODB_DB_NAME=sifter

# -----------------------------------------------------------------------------
# Required — Google Cloud Storage (PDFs: OCR download, Gmail sync attachments)
# -----------------------------------------------------------------------------
# Worker stages use GCS_BUCKET (process.env.GCS_BUCKET in ocr.ts + gmail-sync.ts).
GCS_BUCKET=
# Base64-encoded GCP service account JSON. On Fly.io, set this as a secret.
# The entrypoint decodes it to /tmp/gcp-key.json and sets GOOGLE_APPLICATION_CREDENTIALS.
GCP_CREDENTIALS_JSON=
# Local dev (worktree root): decode JSON once next to this repo, then point here:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/.worktrees/<name>/gcp-sa-key.json

# -----------------------------------------------------------------------------
# Required — OpenAI (classify / normalize / audit stages)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Gmail sync (packages/core email poller + worker gmail-sync job)
# -----------------------------------------------------------------------------
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=

# How far back to search mail on sync (default 60)
# EMAIL_BACKLOG_DAYS=60

# -----------------------------------------------------------------------------
# OAuth token decryption (mailbox tokens in DB)
# -----------------------------------------------------------------------------
# Full KMS crypto key resource name for production.
# In development, if unset, NODE_ENV=development uses base64 plaintext fallback (see packages/core oauth-token-crypto).
OAUTH_KMS_KEY_NAME=

# -----------------------------------------------------------------------------
# Fly.io autoscaler (optional locally — without these, scaler logs errors every 30s but workers still run)
# -----------------------------------------------------------------------------
# FLY_API_TOKEN=
# FLY_APP_NAME=sifter-worker
# JOBS_PER_MACHINE=5
# MIN_MACHINES=1
# MAX_MACHINES=5

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
# NODE_ENV=development
